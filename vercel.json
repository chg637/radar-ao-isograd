{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "dashboard",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
